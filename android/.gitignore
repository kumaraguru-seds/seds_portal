# gradle-wrapper.jar, gradlew, and gradlew.bat MUST be committed.
# GitHub Actions CI needs them to build the Android APK on Linux runners.
# gradle-wrapper.jar   ← DO NOT exclude
# /gradlew             ← DO NOT exclude
# /gradlew.bat         ← DO NOT exclude
/.gradle
/captures/
/local.properties
GeneratedPluginRegistrant.java
.cxx/

# Remember to never publicly share your keystore.
# See https://flutter.dev/to/reference-keystore
key.properties
**/*.keystore
**/*.jks
